VertexLitGeneric
{
	$basetexture "models/glorp_materials/glorp_eyes"

	 $phong 1
	$phongexponent "5"
	$phongboost "0.3"
	$phongfresnelranges "[8.6 .85 30]"
	$PhongAlbedoTint "1"
	$rimlight 				"12"	
	$rimlightexponent 			"50"
	$rimlightboost			"0.1"
	$model				"1"
	$nodecal "1"
	
	$rand 500
	$five 5
	$zpt 0.3
	$one 0.99999
	$six 9
	$oth 360
"Proxies"
   {

	"EntityRandom"
           	 {
                "scale" "1.99"
                "resultVar" "$zpt"
               	}

	"LessOrEqual"
     	   {
          	  "LessEqualVar" "$five"
          	  "greaterVar" "$oth"
          	  "srcVar1" "$rand"
           	  "srcVar2" "$one"            
          	  "resultVar" "$phongexponent"    
       	  }

	"LessOrEqual"
     	   {
          	  "LessEqualVar" "$zpt"
          	  "greaterVar" "$six"
          	  "srcVar1" "$rand"
           	  "srcVar2" "$one"            
          	  "resultVar" "$phongboost"    
       	  }

	"LessOrEqual"
     	   {
          	  "LessEqualVar" "$zero "
          	  "greaterVar" "$po"
          	  "srcVar1" "$rand"
           	  "srcVar2" "$one"            
          	  "resultVar" "$detailblendfactor"    
       	  }



   }

}
